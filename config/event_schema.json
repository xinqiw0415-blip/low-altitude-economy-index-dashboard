{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LowAltitudeEconomicEvent",
  "type": "object",
  "required": [
    "event_id", "document_id", "event_date", "event_type", "actor",
    "region", "direction", "intensity", "uncertainty", "evidence_span", "confidence"
  ],
  "properties": {
    "event_id": {"type": "string"},
    "document_id": {"type": "string"},
    "event_date": {"type": "string", "format": "date"},
    "event_type": {
      "enum": ["strategic_plan", "support_measure", "regulation", "airspace_reform", "infrastructure", "fiscal_subsidy", "industry_standard", "insurance_finance", "other"]
    },
    "actor": {"type": "string"},
    "region": {"type": "string"},
    "policy_level": {"enum": ["central", "province", "city", "district", "company", "other"]},
    "policy_tools": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "targets": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "direction": {"enum": ["positive", "negative", "mixed", "neutral"]},
    "intensity": {"type": "integer", "minimum": 1, "maximum": 5},
    "uncertainty": {"type": "integer", "minimum": 1, "maximum": 5},
    "novelty": {"type": "integer", "minimum": 1, "maximum": 5},
    "evidence_span": {"type": "string", "minLength": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "extraction_method": {"enum": ["human", "llm", "rule_baseline"]}
  }
}
